# Monarch Insights — local user config.
#
# Everything in this file is OPTIONAL. The library gets account IDs, names,
# institutions, types, and balances directly from Monarch's API. You only need to
# provide:
#
#   * Which checking account to use for the 60-day balance forecast
#   * Filing status (Monarch doesn't know this)
#   * Target asset allocation (drift alerts need it)
#   * Watchlist tickers you don't own but want alerts on
#   * Alert thresholds + which HA notify.* service receives warns
#
# Search order for this file (first match wins):
#   1. $MONARCH_INSIGHTS_CONFIG (explicit env override)
#   2. /config/monarch_insights.yaml         (Home Assistant OS)
#   3. ~/.config/monarch-insights/user.yaml  (CLI / desktop)
#   4. ./monarch_insights.yaml               (project root, for dev)
#
# This file stays on your machine — the repo never knows it exists.
# Use `monarch-insights config init` to generate a minimal version automatically
# after your first Monarch sync.

# --- Required for most insights ---

# Federal filing status — valid: single | mfj | mfs | hoh.
filing_status: single

# Which Monarch account is your primary checking. Run `monarch-insights insight
# networth` after your first sync to see account IDs.
primary_checking_account_id: ACT_REPLACE_ME


# --- Strongly recommended ---

# Target asset allocation. Drift alerts fire when any bucket exceeds its threshold.
# Buckets map to tickers via monarch_insights/insights/investments.py::KNOWN_TICKER_BUCKETS
# — the classifier covers ~40 common ETFs/mutual funds out of the box.
allocation_targets:
  us_stock:   {target_pct: 60, drift_threshold_pct: 5}
  intl_stock: {target_pct: 25, drift_threshold_pct: 5}
  bond:       {target_pct: 15, drift_threshold_pct: 5}

# Alert engine tuning.
alerts:
  low_balance_floor: 1500          # USD below which the 60-day forecast fires a warning
  concentration_threshold_pct: 15  # single ticker above this % of portfolio = alert
  price_move_threshold_pct: 5      # watchlist price-move alert threshold
  notify_service: notify.mobile_app_your_phone   # HA notify.* service for warn-tier alerts


# --- Optional: watchlist (tickers you don't own but want alerts on) ---

watchlist:
  - {symbol: VTI,  kind: buy_below,  target_price: 240}
  - {symbol: NVDA, kind: alert_move, move_threshold_pct: 5}
  - {symbol: AAPL, kind: alert_move, move_threshold_pct: 3}


# --- Optional: account aliases ---
# Only needed if you want display names in alerts/digests to differ from Monarch's
# labels, or to tag one account as "primary brokerage" for signal routing. If you
# omit this section entirely, the library uses Monarch's display_name for every
# account automatically.

# accounts:
#   ACT_1f3a…:
#     display_name: Everyday Checking   # override Monarch's name in notifications
#   ACT_9c4d…:
#     display_name: Main Brokerage
#     is_primary_brokerage: true        # used for watchlist evaluation routing
